rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can read and write only their own document and subcollections.
    // Subcollections: widgets, notes, integrations
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      match /{subcollection=**} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Shared / public config — any signed-in user can read.
    // Only writable from the Firebase console or Admin SDK (not the client).
    match /sharedConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
